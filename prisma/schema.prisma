model GuestBlacklist {
  id           Int      @id @default(autoincrement())
  guestName    String
  phone        String   @default("")
  email        String   @default("")
  reason       String
  severity     String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  addedBy      String   @default("")
  status       String   @default("ACTIVE") // ACTIVE, LIFTED
  liftedAt     DateTime?
  liftedBy     String   @default("")
  liftReason   String   @default("")
  notes        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@map("guest_blacklist")
}

model MenuCategory {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  displayOrder Int      @default(0)
  icon         String   @default("🍽️")
  color        String   @default("#2653a0")
  description  String   @default("")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@map("menu_categories")
}

model PrepChecklist {
  id             Int      @id @default(autoincrement())
  name           String
  checklistType  String   @default("OPENING") // OPENING, CLOSING, CUSTOM
  shift          String   @default("MORNING")
  date           DateTime @default(now())
  items          String   @default("[]") // JSON array of {label, done, doneBy, doneAt}
  status         String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  completedBy    String   @default("")
  completedAt    DateTime?
  notes          String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@map("prep_checklists")
}

model StaffRecognition {
  id           Int      @id @default(autoincrement())
  staffId      Int
  staffName    String   @default("")
  month        Int      // 1-12
  year         Int
  award        String   @default("EMPLOYEE_OF_MONTH") // EMPLOYEE_OF_MONTH, BEST_SERVICE, MOST_IMPROVED, PUNCTUALITY, TEAM_PLAYER
  nominatedBy  String   @default("")
  reason       String   @default("")
  votes        Int      @default(0)
  status       String   @default("NOMINATED") // NOMINATED, APPROVED, AWARDED
  approvedBy   String   @default("")
  notes        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([staffId, month, year, award])
  @@map("staff_recognitions")
}

model IncidentLog {
  id            Int      @id @default(autoincrement())
  incidentDate  DateTime @default(now())
  type          String   @default("ACCIDENT") // ACCIDENT, INJURY, THEFT, COMPLAINT, SAFETY, OTHER
  title         String
  description   String   @default("")
  involvedParty String   @default("")
  reportedBy    String   @default("")
  witnesses     String   @default("")
  severity      String   @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  actionTaken   String   @default("")
  followUpDate  DateTime?
  status        String   @default("OPEN") // OPEN, INVESTIGATING, RESOLVED, CLOSED
  resolvedBy    String   @default("")
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@map("incident_logs")
}
