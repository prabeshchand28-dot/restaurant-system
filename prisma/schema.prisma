generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────
// RESTAURANT (Multi-tenant)
// ─────────────────────────────────────
model Restaurant {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("restaurants")
}


// ─────────────────────────────────────
// USERS
// ─────────────────────────────────────
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  password     String
  name         String
  role         String   // admin | manager | waiter | kitchen
  email        String   @default("")
  phone        String   @default("")
  active       Boolean  @default(true)
  restaurantId Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// ─────────────────────────────────────
// RESTAURANT TABLES
// ─────────────────────────────────────
model RestaurantTable {
  id           Int           @id @default(autoincrement())
  number       Int
  capacity     Int           @default(4)
  active       Boolean       @default(true)
  restaurantId Int           @default(1)
  orders       Order[]
  guests       Guest[]
  reservations Reservation[]

  @@unique([restaurantId, number])
  @@map("restaurant_tables")
}

// ─────────────────────────────────────
// MENU ITEMS
// ─────────────────────────────────────
model MenuItem {
  id           Int         @id @default(autoincrement())
  name         String
  price        Int
  category     String
  restaurantId Int         @default(1)
  image      String?
  available  Boolean     @default(true)
  featured   Boolean     @default(false)
  discount   Int         @default(0)
  waitMins   Int         @default(10)
  allergens  String[]    @default([])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]

  @@map("menu_items")
}

// ─────────────────────────────────────
// ORDERS
// ─────────────────────────────────────
model Order {
  id            Int              @id @default(autoincrement())
  restaurantId  Int              @default(1)
  tableNumber   Int
  tableId       Int?
  status        String           @default("Pending")
  estimatedWait Int              @default(10)
  guestCount    Int              @default(1)
  notes         String           @default("")
  createdAt     DateTime         @default(now())
  completedAt   DateTime?
  items         OrderItem[]
  payment       Payment?
  table         RestaurantTable? @relation(fields: [tableId], references: [id])

  @@map("orders")
}

// ─────────────────────────────────────
// ORDER ITEMS
// ─────────────────────────────────────
model OrderItem {
  id       Int       @id @default(autoincrement())
  orderId  Int
  menuId   Int?
  name     String
  price    Int
  qty      Int
  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem? @relation(fields: [menuId], references: [id])

  @@map("order_items")
}

// ─────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────
model Payment {
  id           Int      @id @default(autoincrement())
  restaurantId Int      @default(1)
  orderId      Int      @unique
  method     String
  amount     Int
  amountPaid Int
  change     Int      @default(0)
  receiptNo  String   @default("")
  status     String   @default("Paid")
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────
// GUESTS
// ─────────────────────────────────────
model Guest {
  id           Int              @id @default(autoincrement())
  restaurantId Int              @default(1)
  tableNum     Int
  tableId   Int?
  count     Int
  gender    String           @default("Mixed")
  createdAt DateTime         @default(now())
  tableRel  RestaurantTable? @relation(fields: [tableId], references: [id])

  @@map("guests")
}

// ─────────────────────────────────────
// RESERVATIONS
// ─────────────────────────────────────
model Reservation {
  id           Int              @id @default(autoincrement())
  restaurantId Int              @default(1)
  name         String
  phone     String
  guests    Int
  date      String
  time      String
  tableNo   Int?
  note      String           @default("")
  status    String           @default("Confirmed")
  tableId   Int?
  tableRel  RestaurantTable? @relation(fields: [tableId], references: [id])
  createdAt DateTime         @default(now())

  @@map("reservations")
}

// ─────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────
model InventoryItem {
  id           Int      @id @default(autoincrement())
  restaurantId Int      @default(1)
  name         String
  quantity  Float
  unit      String
  minStock  Float    @default(0)
  category  String   @default("General")
  updatedAt DateTime @updatedAt

  @@map("inventory")
}

// ─────────────────────────────────────
// RATINGS
// ─────────────────────────────────────
model Rating {
  id        Int      @id @default(autoincrement())
  tableNum  Int
  orderId   Int?
  overall   Int
  food      Int
  service   Int
  comment   String   @default("")
  createdAt DateTime @default(now())

  @@map("ratings")
}

// ─────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────
model Attendance {
  id           Int       @id @default(autoincrement())
  restaurantId Int       @default(1)
  userId       Int
  userName   String
  userRole   String
  date       String    // YYYY-MM-DD
  checkIn    DateTime?
  checkOut   DateTime?
  hoursWorked Float?
  status     String    @default("Present") // Present | Late | Absent | Half-Day
  note       String    @default("")
  createdAt  DateTime  @default(now())

  @@unique([userId, date])
  @@map("attendance")
}

// ─────────────────────────────────────
// SETTINGS (key-value store)
// ─────────────────────────────────────
model Setting {
  id           Int      @id @default(autoincrement())
  restaurantId Int      @default(1)
  key          String
  value        String
  updatedAt    DateTime @updatedAt

  @@unique([restaurantId, key])
  @@map("settings")
}

// ─────────────────────────────────────
// LOYALTY PROGRAM
// ─────────────────────────────────────
model LoyaltyAccount {
  id           Int            @id @default(autoincrement())
  phone        String         @unique
  name         String
  email        String         @default("")
  totalPoints  Int            @default(0)
  totalSpent   Int            @default(0)
  tier         String         @default("Bronze") // Bronze | Silver | Gold | Platinum
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  transactions LoyaltyTx[]

  @@map("loyalty_accounts")
}

model LoyaltyTx {
  id          Int            @id @default(autoincrement())
  accountId   Int
  type        String         // earn | redeem | adjust
  points      Int
  description String         @default("")
  orderId     Int?
  createdAt   DateTime       @default(now())
  account     LoyaltyAccount @relation(fields: [accountId], references: [id])

  @@map("loyalty_transactions")
}

// ─────────────────────────────────────
// COUPONS & DISCOUNTS
// ─────────────────────────────────────
model Coupon {
  id           Int      @id @default(autoincrement())
  restaurantId Int      @default(1)
  code         String
  type        String   // percent | fixed
  value       Float
  minOrder    Int      @default(0)
  maxUses     Int      @default(0) // 0 = unlimited
  usedCount   Int      @default(0)
  active      Boolean  @default(true)
  expiresAt   DateTime?
  description String   @default("")
  createdAt   DateTime @default(now())

  @@unique([restaurantId, code])
  @@map("coupons")
}

// ─────────────────────────────────────
// CUSTOMER PROFILES (CRM)
// ─────────────────────────────────────
model CustomerProfile {
  id             Int      @id @default(autoincrement())
  name           String
  phone          String   @unique
  email          String   @default("")
  birthday       String   @default("") // MM-DD
  allergyNotes   String   @default("")
  preferences    String   @default("")
  visitCount     Int      @default(0)
  totalSpent     Int      @default(0)
  lastVisit      DateTime?
  segment        String   @default("Regular") // New | Regular | VIP | Inactive
  notes          String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("customer_profiles")
}

// ─────────────────────────────────────
// SUPPLIERS
// ─────────────────────────────────────
model Supplier {
  id             Int             @id @default(autoincrement())
  restaurantId   Int             @default(1)
  name           String
  contact        String          @default("")
  phone          String          @default("")
  email          String          @default("")
  address        String          @default("")
  category       String          @default("General")
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  @@map("suppliers")
}

// ─────────────────────────────────────
// SHIFT SCHEDULING
// ─────────────────────────────────────
model Shift {
  id        Int      @id @default(autoincrement())
  userId    Int
  userName  String
  userRole  String
  date      String   // YYYY-MM-DD
  startTime String   // HH:MM
  endTime   String   // HH:MM
  position  String   @default("")
  notes     String   @default("")
  status    String   @default("Scheduled") // Scheduled | Completed | NoShow
  createdAt DateTime @default(now())

  @@map("shifts")
}

// ─────────────────────────────────────
// EXPENSE TRACKING
// ─────────────────────────────────────
model Expense {
  id           Int      @id @default(autoincrement())
  restaurantId Int      @default(1)
  category     String   // Rent | Utilities | Supplies | Staff | Marketing | Other
  description String
  amount      Int
  date        String   // YYYY-MM-DD
  paymentMode String   @default("Cash") // Cash | Bank | Card
  receiptRef  String   @default("")
  createdBy   String   @default("")
  createdAt   DateTime @default(now())

  @@map("expenses")
}

// ─────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────
model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  userName   String   @default("")
  userRole   String   @default("")
  action     String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | PAYMENT
  resource   String   // orders | payments | menu | staff | etc.
  resourceId String   @default("")
  details    String   @default("")
  ip         String   @default("")
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

// ─────────────────────────────────────
// PAYROLL
// ─────────────────────────────────────
model StaffPayRate {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  userName   String
  userRole   String
  hourlyRate Int      @default(0)
  monthlyRate Int     @default(0)
  payType    String   @default("hourly") // hourly | monthly
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("staff_pay_rates")
}

model Payroll {
  id          Int      @id @default(autoincrement())
  userId      Int
  userName    String
  userRole    String
  month       String   // YYYY-MM
  hoursWorked Float    @default(0)
  basePay     Int      @default(0)
  overtime    Int      @default(0)
  deductions  Int      @default(0)
  bonus       Int      @default(0)
  netPay      Int      @default(0)
  status      String   @default("Draft") // Draft | Approved | Paid
  notes       String   @default("")
  createdAt   DateTime @default(now())

  @@unique([userId, month])
  @@map("payrolls")
}

// ─────────────────────────────────────
// LEAVE MANAGEMENT
// ─────────────────────────────────────
model LeaveRequest {
  id          Int      @id @default(autoincrement())
  userId      Int
  userName    String
  userRole    String
  type        String   // Annual | Sick | Emergency | Unpaid
  startDate   String   // YYYY-MM-DD
  endDate     String   // YYYY-MM-DD
  days        Int      @default(1)
  reason      String   @default("")
  status      String   @default("Pending") // Pending | Approved | Rejected
  reviewedBy  String   @default("")
  reviewNote  String   @default("")
  createdAt   DateTime @default(now())

  @@map("leave_requests")
}

// ─────────────────────────────────────
// RECIPE COSTING
// ─────────────────────────────────────
model Recipe {
  id          Int           @id @default(autoincrement())
  menuItemId  Int?
  name        String
  servings    Int           @default(1)
  totalCost   Float         @default(0)
  salePrice   Int           @default(0)
  profitMargin Float        @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  ingredients RecipeItem[]

  @@map("recipes")
}

model RecipeItem {
  id           Int      @id @default(autoincrement())
  recipeId     Int
  ingredientName String
  qty          Float
  unit         String
  costPerUnit  Float
  totalCost    Float
  recipe       Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_items")
}

// ─────────────────────────────────────
// HAPPY HOUR & PROMOTIONS
// ─────────────────────────────────────
model Promotion {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("")
  type        String   // happyhour | seasonal | combo | bogo | flatdiscount
  discountPct Int      @default(0)
  discountAmt Int      @default(0)
  startDate   String?  // YYYY-MM-DD
  endDate     String?
  startTime   String?  // HH:MM (for happy hour)
  endTime     String?
  days        String   @default("") // comma-separated: Mon,Tue,Wed...
  active      Boolean  @default(true)
  applyTo     String   @default("all") // all | category | item
  applyValue  String   @default("")
  createdAt   DateTime @default(now())

  @@map("promotions")
}

// ─────────────────────────────────────
// CUSTOMER WALLET
// ─────────────────────────────────────
model CustomerWallet {
  id           Int         @id @default(autoincrement())
  phone        String      @unique
  name         String
  balance      Int         @default(0)
  totalTopUp   Int         @default(0)
  totalSpent   Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  transactions WalletTx[]

  @@map("customer_wallets")
}

model WalletTx {
  id          Int            @id @default(autoincrement())
  walletId    Int
  type        String         // topup | spend | refund
  amount      Int
  description String         @default("")
  orderId     Int?
  createdAt   DateTime       @default(now())
  wallet      CustomerWallet @relation(fields: [walletId], references: [id])

  @@map("wallet_transactions")
}

// ─────────────────────────────────────
// MEMBERSHIP PROGRAM
// ─────────────────────────────────────
model Membership {
  id           Int      @id @default(autoincrement())
  phone        String   @unique
  name         String
  email        String   @default("")
  tier         String   @default("Basic") // Basic | Silver | Gold | Platinum
  startDate    String
  expiryDate   String
  autoDiscount Int      @default(0) // % discount on all orders
  perks        String   @default("") // comma-separated perks
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("memberships")
}

// ─────────────────────────────────────
// PHASE 3: MULTI-BRANCH
// ─────────────────────────────────────
model Branch {
  id        Int      @id @default(autoincrement())
  name      String
  address   String   @default("")
  phone     String   @default("")
  email     String   @default("")
  manager   String   @default("")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("branches")
}

// ─────────────────────────────────────
// PHASE 3: DELIVERY MANAGEMENT
// ─────────────────────────────────────
model DeliveryZone {
  id            Int      @id @default(autoincrement())
  name          String
  minDistance   Float    @default(0)
  maxDistance   Float
  deliveryFee   Float    @default(0)
  estimatedMins Int      @default(30)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  orders DeliveryOrder[]

  @@map("delivery_zones")
}

model DeliveryOrder {
  id             Int      @id @default(autoincrement())
  orderId        Int?
  customerName   String
  customerPhone  String
  address        String
  zoneId         Int?
  driverName     String   @default("")
  driverPhone    String   @default("")
  status         String   @default("PENDING") // PENDING | ASSIGNED | PICKED | DELIVERED | CANCELLED
  deliveryFee    Float    @default(0)
  estimatedMins  Int      @default(30)
  notes          String   @default("")
  createdAt      DateTime @default(now())
  deliveredAt    DateTime?

  zone DeliveryZone? @relation(fields: [zoneId], references: [id])

  @@map("delivery_orders")
}

// ─────────────────────────────────────
// PHASE 3: NOTIFICATIONS
// ─────────────────────────────────────
model NotificationTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  event     String   // ORDER_READY | RESERVATION_CONFIRMED | LOW_STOCK | etc.
  channel   String   @default("SMS") // SMS | EMAIL | BOTH
  subject   String   @default("")
  body      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("notification_templates")
}

model NotificationLog {
  id         Int      @id @default(autoincrement())
  event      String
  channel    String
  recipient  String
  subject    String   @default("")
  body       String
  status     String   @default("SENT") // SENT | FAILED | PENDING
  error      String   @default("")
  createdAt  DateTime @default(now())

  @@map("notification_logs")
}

// ─────────────────────────────────────
// PHASE 3: TAX CONFIGURATION
// ─────────────────────────────────────
model TaxRate {
  id          Int      @id @default(autoincrement())
  name        String
  rate        Float    // percentage e.g. 13
  category    String   @default("ALL") // ALL | FOOD | BEVERAGE | SERVICE
  inclusive   Boolean  @default(false) // tax included in price?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("tax_rates")
}

// ─────────────────────────────────────
// PHASE 3: STOCK HISTORY
// ─────────────────────────────────────
model StockHistory {
  id              Int      @id @default(autoincrement())
  inventoryItemId Int
  changeType      String   // ADD | REMOVE | ADJUST | REORDER
  quantityBefore  Float
  quantityAfter   Float
  change          Float
  reason          String   @default("")
  staffName       String   @default("")
  createdAt       DateTime @default(now())

  @@map("stock_history")
}

// ─────────────────────────────────────
// PHASE 3: DAILY CLOSING REPORT
// ─────────────────────────────────────
model ClosingReport {
  id            Int      @id @default(autoincrement())
  date          String   @unique
  totalOrders   Int      @default(0)
  totalRevenue  Float    @default(0)
  totalExpenses Float    @default(0)
  netProfit     Float    @default(0)
  cashSales     Float    @default(0)
  cardSales     Float    @default(0)
  topItems      String   @default("") // JSON
  notes         String   @default("")
  closedBy      String   @default("")
  createdAt     DateTime @default(now())

  @@map("closing_reports")
}

// ─────────────────────────────────────
// PHASE 4: ONLINE ORDERING
// ─────────────────────────────────────
model OnlineOrder {
  id            Int      @id @default(autoincrement())
  customerName  String
  customerPhone String
  customerEmail String   @default("")
  orderType     String   @default("DELIVERY") // DELIVERY | PICKUP
  address       String   @default("")
  status        String   @default("PENDING") // PENDING | CONFIRMED | PREPARING | READY | DELIVERED | CANCELLED
  subtotal      Float    @default(0)
  deliveryFee   Float    @default(0)
  tax           Float    @default(0)
  total         Float    @default(0)
  paymentMethod String   @default("CASH") // CASH | STRIPE | ESEWA | KHALTI
  paymentStatus String   @default("PENDING") // PENDING | PAID | FAILED
  stripePaymentId String @default("")
  notes         String   @default("")
  estimatedMins Int      @default(30)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items OnlineOrderItem[]

  @@map("online_orders")
}

model OnlineOrderItem {
  id           Int    @id @default(autoincrement())
  onlineOrderId Int
  menuItemId   Int?
  name         String
  price        Float
  quantity     Int
  notes        String @default("")

  order OnlineOrder @relation(fields: [onlineOrderId], references: [id], onDelete: Cascade)

  @@map("online_order_items")
}

// ─────────────────────────────────────
// PHASE 4: MARKETING CAMPAIGNS
// ─────────────────────────────────────
model MarketingCampaign {
  id           Int      @id @default(autoincrement())
  name         String
  channel      String   @default("SMS") // SMS | EMAIL | BOTH
  subject      String   @default("")
  message      String
  targetGroup  String   @default("ALL") // ALL | LOYALTY | VIP | INACTIVE
  status       String   @default("DRAFT") // DRAFT | SCHEDULED | SENT | CANCELLED
  sentCount    Int      @default(0)
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime @default(now())

  @@map("marketing_campaigns")
}

// ─────────────────────────────────────
// PHASE 4: STAFF PERFORMANCE
// ─────────────────────────────────────
model StaffPerformanceLog {
  id          Int      @id @default(autoincrement())
  staffId     Int
  metric      String   // ORDERS_SERVED | RATING | UPSELL | COMPLAINT | COMMENDATION
  value       Float    @default(0)
  note        String   @default("")
  recordedBy  String   @default("")
  createdAt   DateTime @default(now())

  @@map("staff_performance_logs")
}

// ─────────────────────────────────────
// PHASE 4: STRIPE / PAYMENT GATEWAY
// ─────────────────────────────────────
model PaymentGatewaySetting {
  id        Int      @id @default(autoincrement())
  gateway   String   @unique // STRIPE | ESEWA | KHALTI
  enabled   Boolean  @default(false)
  publicKey String   @default("")
  secretKey String   @default("") // stored encrypted in production
  webhookSecret String @default("")
  testMode  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("payment_gateway_settings")
}

// ─────────────────────────────────────
// PHASE 5: FOOD WASTE TRACKING
// ─────────────────────────────────────
model WasteLog {
  id         Int      @id @default(autoincrement())
  menuItemId Int?
  itemName   String
  category   String   @default("")
  quantity   Float
  unit       String   @default("portion")
  reason     String   @default("SPOILAGE") // SPOILAGE | OVERPRODUCTION | DROPPED | EXPIRED | QUALITY
  costPerUnit Float   @default(0)
  totalCost  Float    @default(0)
  staffId    Int?
  staffName  String   @default("")
  notes      String   @default("")
  date       DateTime @default(now())
  createdAt  DateTime @default(now())

  @@map("waste_logs")
}

// ─────────────────────────────────────
// PHASE 5: EVENT / BANQUET MANAGEMENT
// ─────────────────────────────────────
model Event {
  id           Int      @id @default(autoincrement())
  name         String
  type         String   @default("PRIVATE") // PRIVATE | BANQUET | CATERING | CORPORATE | WEDDING
  clientName   String
  clientPhone  String   @default("")
  clientEmail  String   @default("")
  eventDate    DateTime
  startTime    String   @default("")
  endTime      String   @default("")
  venue        String   @default("")
  guestCount   Int      @default(0)
  status       String   @default("INQUIRY") // INQUIRY | CONFIRMED | DEPOSIT_PAID | COMPLETED | CANCELLED
  totalAmount  Float    @default(0)
  depositPaid  Float    @default(0)
  notes        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items EventItem[]

  @@map("events")
}

model EventItem {
  id          Int    @id @default(autoincrement())
  eventId     Int
  description String
  quantity    Int    @default(1)
  unitPrice   Float  @default(0)
  total       Float  @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_items")
}

// ─────────────────────────────────────
// PHASE 5: STAFF WEEKLY ROSTER
// ─────────────────────────────────────
model RosterEntry {
  id          Int      @id @default(autoincrement())
  staffId     Int
  weekStart   DateTime // always a Monday
  dayOfWeek   Int      // 0=Mon … 6=Sun
  startTime   String
  endTime     String
  role        String   @default("")
  note        String   @default("")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([staffId, weekStart, dayOfWeek])
  @@map("roster_entries")
}

